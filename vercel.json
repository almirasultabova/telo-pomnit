{
  "rewrites": [
    { "source": "/", "destination": "/landing_final.html" },
    { "source": "/guide", "destination": "/gaid-body-stress.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
