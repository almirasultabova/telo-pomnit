# Пример переменных окружения для бэкенда «Тело помнит»
# Скопируй этот файл в backend/.env и заполни значения

# ─── База данных (Supabase) ───────────────────────────────────────────────
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# ─── Telegram бот ─────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_IDS=123456789    # Telegram ID ведущей — через запятую если несколько

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=any_random_secret_string_at_least_32_chars

# ─── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...      # platform.openai.com/api-keys

# ─── ЮKassa (заполнить после одобрения) ──────────────────────────────────
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
WEBHOOK_SECRET=

# ─── URLs ─────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
MINI_APP_URL=https://telo-pomnit.ru/tg-app/
